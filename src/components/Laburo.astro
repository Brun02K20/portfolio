---
interface Props {
  title: string;
  experience: string[];
  date: string;
}

const { title, experience, date } = Astro.props;
---

<ul class="ml-6 my-4">
  <li>
    <p class="font-semibold text-lg">{title}</p>
    <p class="text-gray-400 text-sm">{date}</p>
  </li>
  <li>
    <ul class="list-disc ml-12">
      {experience.map((exp, index) => <li class="text-base">{exp}</li>)}
    </ul>
  </li>
</ul>
